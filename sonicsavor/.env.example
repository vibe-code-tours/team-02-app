# OpenAI
OPENAI_API_KEY=sk-or-v1-your-key-here

# Spotify
# Client ID is used for both Client Credentials (playlist search) and user OAuth (Web Playback SDK)
SPOTIFY_CLIENT_ID=your-client-id
# Client Secret is only needed for server-side token exchange (Authorization Code flow)
SPOTIFY_CLIENT_SECRET=your-client-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Access Code (for generating user codes)
ADMIN_ACCESS_CODE=sonicsavor-admin-2024
NEXT_PUBLIC_ADMIN_ACCESS_CODE=sonicsavor-admin-2024
